# Required for OpenAI
OPENAI_API_KEY=your_openai_api_key

# Required for Firebase Admin SDK (single-line JSON string)
# Example format:
# FIREBASE_KEY={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n","client_email":"...","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"..."}
FIREBASE_KEY=

# Optional
# CORS_ORIGIN=https://your-mobile-app-domain.com
